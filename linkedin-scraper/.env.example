# ──────────────────────────────────────────────
#  LinkedIn Scraper — Configuración
# ──────────────────────────────────────────────

# Credenciales de LinkedIn
LINKEDIN_EMAIL=tu@email.com
LINKEDIN_PASSWORD=tu_contraseña

# Búsqueda
# Ejemplos: "property manager Melbourne", "real estate CEO Sydney"
SEARCH_QUERY=property manager Australia

# Número máximo de leads a extraer
MAX_LEADS=50

# Delay entre acciones (ms) — no bajar de 2000 para evitar bloqueos
MIN_DELAY_MS=2000
MAX_DELAY_MS=4000

# Archivo de salida (sin extensión)
OUTPUT_FILE=leads_output

# Modo: "search" (búsqueda de personas) | "company" (empleados de empresa)
SCRAPE_MODE=search

# Debug: genera screenshots y vuelca selectores activos de la página
# Activar si no se encuentran resultados: DEBUG=true
DEBUG=false

# ──────────────────────────────────────────────
